{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      }
    ],
     "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "**/*.ts",
    "**/*.tsx"
, "src/components/sidebar/navChatHistorySkeleton.jsx", "src/components/sidebar/nav-main.jsx", "src/components/sidebar/nav-header.jsx", "src/components/sidebar/nav-footer.jsx", "src/components/sidebar/app-sidebar.jsx", "src/components/sidebar/chart-area-interactive.jsx", "src/components/sidebar/nav-user.jsx"  ],
  "exclude": [
    "node_modules"
  ]
}
